{
  "expo": {
    "name": "Roame",
    "slug": "roame",
    "scheme": "roame",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAFAFA",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.roame.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Roame uses your location to show activities near you."
      }
    },
    "android": {
      "package": "app.roame.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-location",
        { "locationWhenInUsePermission": "Roame uses your location to show activities near you." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
