// ─────────────────────────────────────────────────────────────────────────────
// Roame — Prisma schema
//
// Covers all product domains (~60+ tables). Cross-cutting conventions:
//   • id: cuid()           • createdAt / updatedAt    • deletedAt (soft delete)
//   • enums for status/role/type fields
//   • @@index on FKs + hot query paths; composite indexes where noted
//   • PostGIS: location columns are Unsupported("geography(Point, 4326)")
//     and are read/written via raw SQL (see src/lib/utils/geo + docs/DATABASE.md).
//     GiST indexes + RLS policies live in prisma/rls/*.sql.
//
// Milestone 1 fully exercises Auth/Users + Audit. All other domains have their
// tables and relations defined so later milestones add only logic/UI.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis, pgcrypto]
}

// ═════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═════════════════════════════════════════════════════════════════════════════

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
  OTHER
}

enum AuthProviderType {
  PHONE
  EMAIL
  GOOGLE
  APPLE
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  VERIFY_PHONE
}

enum FollowStatus {
  PENDING
  ACCEPTED
}

enum TrustEventType {
  PROFILE_COMPLETED
  PHONE_VERIFIED
  KYC_VERIFIED
  ACTIVITY_HOSTED
  ACTIVITY_ATTENDED
  POSITIVE_REVIEW
  NEGATIVE_REVIEW
  REPORT_UPHELD
  NO_SHOW
}

enum ActivityStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  ARCHIVED
}

enum ActivityVisibility {
  PUBLIC
  FOLLOWERS
  INVITE_ONLY
  PRIVATE
}

enum ParticipantStatus {
  JOINED
  LEFT
  REMOVED
  NO_SHOW
  ATTENDED
}

enum ParticipantRole {
  HOST
  COHOST
  ATTENDEE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum WaitlistStatus {
  WAITING
  PROMOTED
  EXPIRED
  CANCELLED
}

enum CheckinMethod {
  GEO
  QR
  MANUAL
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ConversationType {
  DIRECT
  ACTIVITY
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
  SYSTEM
}

enum NotificationType {
  ACTIVITY_INVITE
  ACTIVITY_REMINDER
  ACTIVITY_UPDATE
  ACTIVITY_CANCELLED
  WAITLIST_PROMOTED
  NEW_FOLLOWER
  NEW_MESSAGE
  CHECKIN_CONFIRMED
  REVIEW_RECEIVED
  REPORT_UPDATE
  SYSTEM_ANNOUNCEMENT
  PAYMENT_UPDATE
}

enum ReportTargetType {
  USER
  ACTIVITY
  MESSAGE
  VENUE
  REVIEW
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ModerationActionType {
  WARN
  REMOVE_CONTENT
  SUSPEND_USER
  BAN_USER
  DISMISS
  RESTORE
}

enum ModerationQueueStatus {
  PENDING
  IN_REVIEW
  ACTIONED
  CLEARED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum VenueStatus {
  PENDING
  ACTIVE
  REJECTED
  CLOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum TransactionType {
  PAYMENT
  REFUND
  PAYOUT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AnnouncementAudience {
  ALL
  USERS
  HOSTS
  ADMINS
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  LOGIN
  LOGOUT
  ROLE_CHANGE
  STATUS_CHANGE
}

// ═════════════════════════════════════════════════════════════════════════════
// AUTH & USERS
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id              String     @id @default(cuid())
  phone           String?    @unique
  email           String?    @unique
  phoneVerifiedAt DateTime?
  emailVerifiedAt DateTime?
  role            UserRole   @default(USER)
  status          UserStatus @default(PENDING)
  passwordHash    String? // admin email/password (mock + supabase fallback)
  lastLoginAt     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  profile               Profile?
  settings              UserSettings?
  trustScore            TrustScore?
  accounts              Account[]
  sessions              Session[]
  otps                  PhoneOtp[]
  devices               Device[]
  interests             UserInterest[]
  trustEvents           TrustScoreEvent[]
  following             Follow[]                  @relation("Follower")
  followers             Follow[]                  @relation("Following")
  blocksMade            Block[]                   @relation("Blocker")
  blocksReceived        Block[]                   @relation("Blocked")
  feedItems             FeedItem[]
  hostedActivities      Activity[]                @relation("ActivityHost")
  participations        ActivityParticipant[]
  invitationsSent       ActivityInvitation[]      @relation("InviteSender")
  invitationsReceived   ActivityInvitation[]      @relation("InviteReceiver")
  waitlistEntries       ActivityWaitlist[]
  checkins              ActivityCheckin[]
  savedActivities       SavedActivity[]
  conversationsOwned    Conversation[]            @relation("ConversationCreator")
  conversationMembers   ConversationParticipant[]
  messages              Message[]
  messageReactions      MessageReaction[]
  messageReads          MessageRead[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference?
  searchHistory         SearchHistory[]
  recommendations       Recommendation[]
  reportsMade           Report[]                  @relation("Reporter")
  reportsReceived       Report[]                  @relation("ReportedUser")
  moderationActions     ModerationAction[]        @relation("Moderator")
  moderationQueueClaims ModerationQueueItem[]     @relation("QueueAssignee")
  kyc                   KycVerification?
  venuesOwned           Venue[]                   @relation("VenueOwner")
  businesses            Business[]                @relation("BusinessOwner")
  bookings              Booking[]
  reviewsAuthored       Review[]                  @relation("ReviewAuthor")
  reviewsReceived       Review[]                  @relation("ReviewSubject")
  payments              Payment[]
  paymentMethods        PaymentMethod[]
  subscriptions         Subscription[]
  invoices              Invoice[]
  analyticsEvents       AnalyticsEvent[]
  userMetrics           UserMetric?
  supportTickets        SupportTicket[]
  supportMessages       SupportMessage[]
  auditLogs             AuditLog[]                @relation("AuditActor")
  announcementsAuthored Announcement[]            @relation("AnnouncementAuthor")

  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String           @id @default(cuid())
  userId            String
  provider          AuthProviderType
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PhoneOtp {
  id          String     @id @default(cuid())
  userId      String?
  phone       String
  codeHash    String
  purpose     OtpPurpose @default(LOGIN)
  attempts    Int        @default(0)
  consumedAt  DateTime?
  expiresAt   DateTime

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([expiresAt])
  @@map("phone_otps")
}

model Profile {
  id           String    @id @default(cuid())
  userId       String    @unique
  displayName  String
  username     String?   @unique
  bio          String?
  avatarUrl    String?
  coverUrl     String?
  gender       Gender?
  dateOfBirth  DateTime?
  city         String?
  // PostGIS home location — see prisma/rls + geo utils.
  homeLocation Unsupported("geography(Point, 4326)")?
  isPrivate    Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([city])
  @@map("profiles")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  language             String   @default("en")
  theme                String   @default("system")
  discoveryRadiusKm    Int      @default(10)
  showOnlineStatus     Boolean  @default(true)
  allowMessagesFrom    String   @default("everyone") // everyone | following | none
  pushEnabled          Boolean  @default(true)
  emailEnabled         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Interest {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String?
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserInterest[]

  @@map("interests")
}

model UserInterest {
  userId     String
  interestId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
  @@index([interestId])
  @@map("user_interests")
}

model Device {
  id          String         @id @default(cuid())
  userId      String
  platform    DevicePlatform
  pushToken   String         @unique
  deviceName  String?
  lastSeenAt  DateTime       @default(now())

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

model TrustScore {
  id            String   @id @default(cuid())
  userId        String   @unique
  score         Int      @default(0)
  level         Int      @default(1)
  lastComputed  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trust_scores")
}

model TrustScoreEvent {
  id        String         @id @default(cuid())
  userId    String
  type      TrustEventType
  delta     Int
  reason    String?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trust_score_events")
}

// ═════════════════════════════════════════════════════════════════════════════
// SOCIAL
// ═════════════════════════════════════════════════════════════════════════════

model Follow {
  id          String       @id @default(cuid())
  followerId  String
  followingId String
  status      FollowStatus @default(ACCEPTED)
  createdAt   DateTime     @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model FeedItem {
  id         String   @id @default(cuid())
  userId     String
  verb       String // e.g. activity.created, user.followed
  objectType String
  objectId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("feed_items")
}

// ═════════════════════════════════════════════════════════════════════════════
// ACTIVITIES & DISCOVERY
// ═════════════════════════════════════════════════════════════════════════════

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  color       String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryTree")
  activities Activity[]

  @@index([parentId])
  @@map("categories")
}

model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  activities ActivityTag[]

  @@map("tags")
}

model Activity {
  id              String             @id @default(cuid())
  hostId          String
  categoryId      String?
  venueId         String?
  title           String
  description     String
  status          ActivityStatus     @default(DRAFT)
  visibility      ActivityVisibility @default(PUBLIC)
  startsAt        DateTime
  endsAt          DateTime?
  capacity        Int?
  waitlistEnabled Boolean            @default(true)
  isPaid          Boolean            @default(false)
  priceCents      Int?
  currency        String             @default("INR")
  addressLine     String?
  city            String?
  // PostGIS event location.
  location        Unsupported("geography(Point, 4326)")?
  checkinRadiusM  Int                @default(150)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  host         User                  @relation("ActivityHost", fields: [hostId], references: [id], onDelete: Cascade)
  category     Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  venue        Venue?                @relation(fields: [venueId], references: [id], onDelete: SetNull)
  tags         ActivityTag[]
  participants ActivityParticipant[]
  invitations  ActivityInvitation[]
  waitlist     ActivityWaitlist[]
  checkins     ActivityCheckin[]
  savedBy      SavedActivity[]
  media        ActivityMedia[]
  conversation Conversation?
  reviews      Review[]
  metrics      ActivityMetric?

  @@index([hostId])
  @@index([categoryId])
  @@index([status, startsAt])
  @@index([city])
  @@index([deletedAt])
  @@map("activities")
}

model ActivityTag {
  activityId String
  tagId      String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([activityId, tagId])
  @@index([tagId])
  @@map("activity_tags")
}

model ActivityParticipant {
  id         String            @id @default(cuid())
  activityId String
  userId     String
  role       ParticipantRole   @default(ATTENDEE)
  status     ParticipantStatus @default(JOINED)
  joinedAt   DateTime          @default(now())
  leftAt     DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
  @@index([activityId, status])
  @@map("activity_participants")
}

model ActivityInvitation {
  id         String           @id @default(cuid())
  activityId String
  senderId   String
  receiverId String
  status     InvitationStatus @default(PENDING)
  message    String?
  respondedAt DateTime?
  expiresAt  DateTime?

  createdAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  sender   User     @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User     @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([activityId, receiverId])
  @@index([receiverId, status])
  @@map("activity_invitations")
}

model ActivityWaitlist {
  id         String         @id @default(cuid())
  activityId String
  userId     String
  position   Int
  status     WaitlistStatus @default(WAITING)
  promotedAt DateTime?

  createdAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([activityId, position])
  @@map("activity_waitlist")
}

model ActivityCheckin {
  id         String        @id @default(cuid())
  activityId String
  userId     String
  method     CheckinMethod @default(GEO)
  // PostGIS captured check-in location.
  location   Unsupported("geography(Point, 4326)")?
  distanceM  Int?
  checkedInAt DateTime     @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
  @@map("activity_checkins")
}

model SavedActivity {
  userId     String
  activityId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([userId, activityId])
  @@index([activityId])
  @@map("saved_activities")
}

model ActivityMedia {
  id         String    @id @default(cuid())
  activityId String
  type       MediaType @default(IMAGE)
  url        String
  width      Int?
  height     Int?
  sortOrder  Int       @default(0)

  createdAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("activity_media")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("search_history")
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  objectType String // activity | user | venue
  objectId   String
  score      Float
  reason     String?
  source     String   @default("heuristic") // heuristic | ai
  servedAt   DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, score])
  @@map("recommendations")
}

// ═════════════════════════════════════════════════════════════════════════════
// COMMUNICATION / CHAT
// ═════════════════════════════════════════════════════════════════════════════

model Conversation {
  id         String           @id @default(cuid())
  type       ConversationType
  title      String?
  activityId String?          @unique
  creatorId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activity     Activity?                 @relation(fields: [activityId], references: [id], onDelete: Cascade)
  creator      User?                     @relation("ConversationCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([type])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  isAdmin        Boolean   @default(false)
  mutedUntil     DateTime?
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  type           MessageType @default(TEXT)
  body           String?
  metadata       Json?

  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions    MessageReaction[]
  reads        MessageRead[]
  attachments  MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model MessageRead {
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model MessageAttachment {
  id        String    @id @default(cuid())
  messageId String
  type      MediaType @default(IMAGE)
  url       String
  width     Int?
  height    Int?

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// ═════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═════════════════════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  activityReminders Boolean  @default(true)
  invites           Boolean  @default(true)
  messages          Boolean  @default(true)
  social            Boolean  @default(true)
  marketing         Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ═════════════════════════════════════════════════════════════════════════════
// SAFETY & MODERATION
// ═════════════════════════════════════════════════════════════════════════════

model Report {
  id             String           @id @default(cuid())
  reporterId     String
  targetType     ReportTargetType
  targetId       String
  reportedUserId String?
  reason         String
  description    String?
  status         ReportStatus     @default(OPEN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  resolvedAt DateTime?

  reporter     User                @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User?               @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  actions      ModerationAction[]
  queueItem    ModerationQueueItem?

  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

model ModerationQueueItem {
  id          String                @id @default(cuid())
  reportId    String                @unique
  assigneeId  String?
  status      ModerationQueueStatus @default(PENDING)
  priority    Int                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  assignee User?  @relation("QueueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@map("moderation_queue")
}

model ModerationAction {
  id          String               @id @default(cuid())
  reportId    String?
  moderatorId String
  type        ModerationActionType
  targetType  ReportTargetType
  targetId    String
  notes       String?

  createdAt DateTime @default(now())

  report    Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  moderator User    @relation("Moderator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@map("moderation_actions")
}

model ContentFlag {
  id         String   @id @default(cuid())
  objectType String
  objectId   String
  label      String // spam | nsfw | harassment | ...
  score      Float    @default(0)
  source     String   @default("auto")
  resolved   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([objectType, objectId])
  @@map("content_flags")
}

model KycVerification {
  id          String    @id @default(cuid())
  userId      String    @unique
  status      KycStatus @default(NOT_STARTED)
  provider    String?
  referenceId String?
  documentType String?
  rejectionReason String?
  verifiedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_verifications")
}

// ═════════════════════════════════════════════════════════════════════════════
// VENUES & BUSINESS
// ═════════════════════════════════════════════════════════════════════════════

model Business {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  gstNumber   String?
  isVerified  Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner  User    @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  venues Venue[]

  @@index([ownerId])
  @@map("businesses")
}

model Venue {
  id          String      @id @default(cuid())
  ownerId     String?
  businessId  String?
  name        String
  description String?
  status      VenueStatus @default(PENDING)
  addressLine String?
  city        String?
  // PostGIS venue location.
  location    Unsupported("geography(Point, 4326)")?
  phone       String?
  website     String?
  capacity    Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner      User?       @relation("VenueOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  business   Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  media      VenueMedia[]
  hours      VenueHour[]
  activities Activity[]
  bookings   Booking[]
  reviews    Review[]

  @@index([status])
  @@index([city])
  @@map("venues")
}

model VenueMedia {
  id        String    @id @default(cuid())
  venueId   String
  type      MediaType @default(IMAGE)
  url       String
  sortOrder Int       @default(0)

  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@map("venue_media")
}

model VenueHour {
  id        String  @id @default(cuid())
  venueId   String
  dayOfWeek Int // 0=Sun..6=Sat
  openMin   Int // minutes from midnight
  closeMin  Int
  isClosed  Boolean @default(false)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, dayOfWeek])
  @@map("venue_hours")
}

model Booking {
  id         String        @id @default(cuid())
  venueId    String
  userId     String
  status     BookingStatus @default(PENDING)
  startsAt   DateTime
  endsAt     DateTime
  partySize  Int           @default(1)
  amountCents Int?
  currency   String        @default("INR")
  paymentId  String?       @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  venue   Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([venueId, startsAt])
  @@index([userId])
  @@map("bookings")
}

// ═════════════════════════════════════════════════════════════════════════════
// REVIEWS
// ═════════════════════════════════════════════════════════════════════════════

model Review {
  id         String   @id @default(cuid())
  authorId   String
  rating     Int // 1..5
  comment    String?
  activityId String?
  venueId    String?
  subjectId  String? // reviewed user (host)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  author   User             @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  subject  User?            @relation("ReviewSubject", fields: [subjectId], references: [id], onDelete: SetNull)
  activity Activity?        @relation(fields: [activityId], references: [id], onDelete: SetNull)
  venue    Venue?           @relation(fields: [venueId], references: [id], onDelete: SetNull)
  response ReviewResponse?

  @@index([activityId])
  @@index([venueId])
  @@index([subjectId])
  @@map("reviews")
}

model ReviewResponse {
  id        String @id @default(cuid())
  reviewId  String @unique
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_responses")
}

// ═════════════════════════════════════════════════════════════════════════════
// PAYMENTS & SUBSCRIPTIONS
// ═════════════════════════════════════════════════════════════════════════════

model Payment {
  id                String          @id @default(cuid())
  userId            String
  provider          PaymentProvider @default(RAZORPAY)
  providerPaymentId String?         @unique
  providerOrderId   String?
  status            PaymentStatus   @default(CREATED)
  amountCents       Int
  currency          String          @default("INR")
  description       String?
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  refunds      Refund[]
  booking      Booking?
  invoice      Invoice?

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Transaction {
  id        String          @id @default(cuid())
  paymentId String
  type      TransactionType
  amountCents Int
  currency  String          @default("INR")
  reference String?

  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("transactions")
}

model Refund {
  id               String   @id @default(cuid())
  paymentId        String
  providerRefundId String?  @unique
  amountCents      Int
  reason           String?

  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refunds")
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  provider    PaymentProvider @default(RAZORPAY)
  token       String
  brand       String?
  last4       String?
  isDefault   Boolean  @default(false)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

model SubscriptionPlan {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  priceCents  Int
  currency    String          @default("INR")
  interval    BillingInterval @default(MONTHLY)
  features    Json?
  isActive    Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(TRIALING)
  providerSubscriptionId String?          @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String?
  paymentId      String?  @unique
  number         String   @unique
  amountCents    Int
  currency       String   @default("INR")
  issuedAt       DateTime @default(now())
  paidAt         DateTime?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("invoices")
}

// ═════════════════════════════════════════════════════════════════════════════
// ANALYTICS
// ═════════════════════════════════════════════════════════════════════════════

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  props     Json?
  sessionId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

model ActivityMetric {
  id            String   @id @default(cuid())
  activityId    String   @unique
  views         Int      @default(0)
  saves         Int      @default(0)
  joins         Int      @default(0)
  checkins      Int      @default(0)
  shareCount    Int      @default(0)

  updatedAt DateTime @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("activity_metrics")
}

model UserMetric {
  id                String   @id @default(cuid())
  userId            String   @unique
  activitiesHosted  Int      @default(0)
  activitiesJoined  Int      @default(0)
  checkinsCount     Int      @default(0)
  followersCount    Int      @default(0)
  followingCount    Int      @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_metrics")
}

// ═════════════════════════════════════════════════════════════════════════════
// CONTENT MANAGEMENT
// ═════════════════════════════════════════════════════════════════════════════

model Announcement {
  id          String               @id @default(cuid())
  authorId    String?
  title       String
  body        String
  audience    AnnouncementAudience @default(ALL)
  isPublished Boolean              @default(false)
  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  author User? @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([isPublished, publishedAt])
  @@map("announcements")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("faqs")
}

model ContentPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  body        String
  isPublished Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_pages")
}

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(MEDIUM)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId])
  @@index([status, priority])
  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  isStaff   Boolean  @default(false)

  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

// ═════════════════════════════════════════════════════════════════════════════
// SYSTEM CONFIGURATION & AUDIT
// ═════════════════════════════════════════════════════════════════════════════

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  isEnabled   Boolean  @default(false)
  rolloutPct  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
