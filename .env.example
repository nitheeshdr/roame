# ─────────────────────────────────────────────────────────────────────────────
# Roame — environment variables
# Copy to `.env` at the repo root. With AUTH_PROVIDER=mock and a local Postgres,
# the whole stack runs with NO real third-party credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (Supabase Postgres / local PostGIS) ─────────────────────────────
# Local PostGIS via Docker:
#   docker run --name roame-db -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgis/postgis:16-3.4
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roame?schema=public"
# Direct (non-pooled) connection, used by Prisma Migrate. Same as DATABASE_URL locally.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/roame?schema=public"

# ── Auth ─────────────────────────────────────────────────────────────────────
# "mock"  → runs locally with deterministic OTP/OAuth, no Supabase needed.
# "supabase" → uses the Supabase keys below.
AUTH_PROVIDER=mock
# Secret used to sign the mock-mode session cookie. Any long random string.
AUTH_SESSION_SECRET="dev-only-change-me-to-a-long-random-string"
# Fixed OTP code returned in mock mode (also logged to the server console).
MOCK_OTP_CODE=000000

# ── Supabase (only required when AUTH_PROVIDER=supabase) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Ola Maps (deferred milestone — placeholder) ─────────────────────────────
OLA_MAPS_API_KEY="your-ola-maps-key"

# ── Google Sign-In (real consumer auth — no OTP, no mock) ───────────────────
# Create an OAuth 2.0 Web client in Google Cloud Console. Add your site to
# "Authorized JavaScript origins" (e.g. http://localhost:3000 and your Vercel URL).
# The id token is verified server-side against this client id.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# ── Razorpay (deferred milestone — placeholder) ─────────────────────────────
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ── AI recommendations (deferred milestone — placeholder) ────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY="your-openai-key"
GEMINI_API_KEY="your-gemini-key"

# ── App URLs ─────────────────────────────────────────────────────────────────
# Single Next.js app: public site at /, admin dashboard at /admin, API at /api.
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000/admin"
